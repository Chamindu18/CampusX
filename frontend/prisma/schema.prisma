/**
 * Prisma database schema.
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =====================================================
 */
/**
 * USER MODEL
 */
/**
 * =====================================================
 */

model User {
  id String @id @default(cuid())

  name String

  email String @unique

  password String

  university String?

  bio String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  /**
   * User marketplace listings.
   */
  listings Listing[]

  /**
   * User chat messages.
   */
  messages Message[]

  /**
   * Saved marketplace listings.
   */
  savedListings SavedListing[]

  /**
   * User notifications.
   */
  notifications Notification[]

  /**
   * User submitted reports.
   */
  reports Report[] @relation("UserReports")

  @@index([email])
  @@index([createdAt])
}

/**
 * =====================================================
 */
/**
 * LISTING MODEL
 */
/**
 * =====================================================
 */

model Listing {
  id String @id @default(cuid())

  title String

  description String

  category String

  /**
   * Stored as float for sorting/filtering.
   */
  price Float

  /**
   * Uploaded cloud image URLs.
   */
  imageUrls String[]

  /**
   * Listing condition.
   */
  condition String

  /**
   * Campus location.
   */
  location String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  /**
   * Owner relation.
   */
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Saved users relation.
   */
  savedBy SavedListing[]

  /**
   * Listing reports.
   */
  reports Report[]

  @@index([userId])
  @@index([category])
  @@index([createdAt])
  @@index([price])
}

/**
 * =====================================================
 */
/**
 * CONVERSATION MODEL
 */
/**
 * =====================================================
 */

model Conversation {
  id String @id @default(cuid())

  createdAt DateTime @default(now())

  /**
   * Conversation messages.
   */
  messages Message[]

  @@index([createdAt])
}

/**
 * =====================================================
 */
/**
 * MESSAGE MODEL
 */
/**
 * =====================================================
 */

model Message {
  id String @id @default(cuid())

  content String

  createdAt DateTime @default(now())

  /**
   * Sender relation.
   */
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Conversation relation.
   */
  conversationId String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([createdAt])
}

/**
 * =====================================================
 */
/**
 * SAVED LISTINGS MODEL
 */
/**
 * =====================================================
 */

model SavedListing {
  id String @id @default(cuid())

  userId String

  listingId String

  /**
   * User relation.
   */
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /**
   * Listing relation.
   */
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  /**
   * Prevent duplicate saves.
   */
  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
}

/**
 * =====================================================
 */
/**
 * NOTIFICATION MODEL
 */
/**
 * =====================================================
 */

model Notification {
  id String @id @default(cuid())

  /**
   * Notification title.
   */
  title String

  /**
   * Notification message.
   */
  message String

  /**
   * Read state.
   */
  isRead Boolean @default(false)

  /**
   * Optional navigation link.
   */
  link String?

  createdAt DateTime @default(now())

  /**
   * Notification owner.
   */
  userId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

/**
 * =====================================================
 */
/**
 * REPORT MODEL
 */
/**
 * =====================================================
 */

model Report {
  id String @id @default(cuid())

  /**
   * Report reason.
   */
  reason String

  /**
   * Optional additional details.
   */
  description String?

  /**
   * Report status.
   */
  status String @default("PENDING")

  createdAt DateTime @default(now())

  /**
   * ==============================
   */
  /**
   * /* REPORTER RELATION
   */
  /**
   * /* ==============================
   */

  reporterId String

  reporter User @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  /**
   * ==============================
   */
  /**
   * /* LISTING RELATION
   */
  /**
   * /* ==============================
   */

  listingId String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([reporterId])
  @@index([listingId])
  @@index([status])
  @@index([createdAt])
}
